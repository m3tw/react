{
  "name": "react-md3",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "test": "vitest run",
    "api:contract:check": "node ./scripts/check-api-contract.mjs",
    "traceability:check": "node ./scripts/check-prd-epics-traceability.mjs",
    "traceability:report": "node ./scripts/check-prd-epics-traceability.mjs --report ../release-evidence/traceability-report.md",
    "m3:coverage:check": "node ./scripts/check-m3-coverage.mjs",
    "m3:coverage:report": "node ./scripts/check-m3-coverage.mjs --report ./docs/m3-coverage-baseline.md",
    "quality:gate": "npm run lint && npm run test && npm run build && npm run api:contract:check && npm run traceability:check && npm run m3:coverage:check",
    "test:watch": "vitest",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^28.1.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
